{
  "name": "daylight-launcher",
  "productName": "Daylight",
  "version": "2.4.0",
  "description": "Daylight — custom Minecraft launcher: modpacks, Fabric mods, modules and Microsoft login",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node tools/make-icon.js",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always && node tools/publish-release.js"
  },
  "author": "Alex",
  "license": "MIT",
  "build": {
    "appId": "gg.daylight.launcher",
    "productName": "Daylight",
    "publish": {
      "provider": "github",
      "owner": "Duckboy121",
      "repo": "daylight-"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bundled",
        "to": "bundled"
      }
    ],
    "afterAllArtifactBuild": "tools/after-build.js",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
